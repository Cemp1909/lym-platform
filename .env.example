NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=TU_PUBLISHABLE_KEY

# Solo servidor. No usar en componentes cliente.
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Dominios permitidos para llamar nuestras rutas /api y futuras Edge Functions.
# En produccion deja solo tu dominio real y el dominio de Vercel si lo usas.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3002
ALLOWED_ORIGINS=http://127.0.0.1:3002,http://localhost:3002,https://distribucioneslym.com,https://www.distribucioneslym.com

# Limite inicial para proteger /api/*.
# Cuando conectemos usuarios reales, los endpoints podran usar el mismo helper por user_id.
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_WINDOW_MS=60000

# Acceso temporal seguro al panel administrador hasta conectar Supabase Auth por rol.
# Usa valores largos y privados en produccion. No subir .env.local a GitHub.
ADMIN_USERNAME=CAMBIA_ESTE_USUARIO_ADMIN
ADMIN_PASSWORD=DistribucionesLYM2026
ADMIN_SESSION_SECRET=GENERA_UN_TOKEN_LARGO_ALEATORIO
